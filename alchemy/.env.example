# Copy to .env and adjust
VLLM_HOST=http://localhost:8000
DRUG_INDEX_PATH=data/drug_index.faiss
DRUG_METADATA_PATH=data/drug_metadata.json
PUBMED_INDEX_PATH=data/pubmed_index.faiss
PUBMED_METADATA_PATH=data/pubmed_metadata.json
# Required for bulk PubMed downloads (NCBI policy)
ENTREZ_EMAIL=you@example.com
ENTREZ_TOOL=alchemy-drug-discovery

# Optional smina (Vina-compatible) — set receptor + box for structure-informed binding scores
# BINDING_USE_SMINA=1
# SMINA_BINARY=smina
# VINA_RECEPTOR_PDBQT=/path/to/receptor.pdbqt
# VINA_BOX_CENTER=10.0,12.0,15.0
# VINA_BOX_SIZE=22,22,22

# Pitch mode: python main.py --offline-demo — uses data/demo_results/chagas_pipeline.json
# ALCHEMY_OFFLINE_DEMO=1
